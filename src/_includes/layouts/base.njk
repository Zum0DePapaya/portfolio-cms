<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default("Daniel Martínez Lozano - Portfolio") }}</title>
    <meta name="description" content="my portfolio :D">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
</head>
<body>
    <div class="site-wrapper">
        <main class="site-main">
            <div class="inner-container">
                {{ content | safe }}
                <div class="credits">
                    <span><a href="https://github.com/Zum0DePapaya/portfolio-cms" target="_blank">Built with 11ty + Decap CMS</a></span>
                </div>
            </div>
        </main>
    </div>
</body>
</html>

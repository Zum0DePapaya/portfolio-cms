---
layout: layouts/base.njk
title: Daniel Martínez Lozano - Portfolio
---

<!-- Header Section -->
<section class="section-container hero-section">
    <div class="hero-content">
        <div class="profile-image-container">
            <img src="{{ landing.profile_image | url }}" alt="{{ landing.name }}" class="profile-image">
        </div>
        <div class="bio-container">
            <h2 class="heading-primary">{{ landing.name }}</h2>
            <p class="text-body lang-en">{{ landing.bio }}</p>
            {% if landing.bio_es %}
            <p class="text-body lang-es">{{ landing.bio_es }}</p>
            {% endif %}
            <div class="social-icons">
                <a href="{{ landing.linkedin_url }}" class="social-icon" aria-label="LinkedIn" target="_blank">
                    <svg viewBox="0 0 40 40"><path d="M12.1,13.8v19.1H5.7V13.8C5.7,13.8,12.1,13.8,12.1,13.8z M12.5,7.9c0,0.9-0.3,1.7-1,2.4c-0.7,0.6-1.5,0.9-2.6,0.9h0 c-1.1,0-1.9-0.3-2.5-0.9c-0.6-0.6-1-1.4-1-2.4c0-1,0.3-1.7,1-2.4S7.9,4.6,9,4.6s1.9,0.3,2.6,0.9S12.5,6.9,12.5,7.9z M35,22v11h-6.4 V22.7c0-1.4-0.3-2.4-0.8-3.2c-0.5-0.8-1.3-1.1-2.4-1.1c-0.8,0-1.5,0.2-2,0.7c-0.5,0.4-1,1-1.2,1.7c-0.1,0.4-0.2,0.9-0.2,1.6v10.7 h-6.4c0-5.1,0-9.3,0-12.5s0-5.1,0-5.7l0-0.9H22v2.8h0c0.3-0.4,0.5-0.8,0.8-1.1c0.3-0.3,0.6-0.6,1.1-1c0.5-0.4,1-0.6,1.7-0.8 c0.7-0.2,1.4-0.3,2.2-0.3c2.2,0,4,0.7,5.3,2.2C34.4,17,35,19.1,35,22L35,22z"></path></svg>
                </a>

            </div>
        </div>
    </div>
</section>

{% for section in landing.sections %}
<h2 class="heading-primary section-title lang-en" id="{{ section.id }}">{{ section.title }}</h2>
{% if section.title_es %}
<h2 class="heading-primary section-title lang-es" id="{{ section.id }}-es">{{ section.title_es }}</h2>
{% endif %}

<section class="section-container {{ section.id }}-section">
    <div class="projects-grid games-grid">
        {% set section_projects = collections.allProjects | filterByCategory(section.id) %}
        {% for project in section_projects %}
        {% if project.data.full_width %}
    </div>
    <hr class="divider">
    <div class="projects-grid games-grid">
        {% endif %}
        <div class="project-item {% if project.data.full_width %}full-width{% endif %}">
            {% set titleParts = project.data.title.split(' - ') %}
            <div class="project-header-info lang-en">
                <h3 class="project-title-main">{{ titleParts[0] }}</h3>
                {% if titleParts.length > 1 %}
                <div class="project-tags">
                    {% for i in range(1, titleParts.length) %}
                        <span class="project-tag">{{ titleParts[i] }}</span>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
            {% if project.data.title_es %}
            {% set titlePartsEs = project.data.title_es.split(' - ') %}
            <div class="project-header-info lang-es">
                <h3 class="project-title-main">{{ titlePartsEs[0] }}</h3>
                {% if titlePartsEs.length > 1 %}
                <div class="project-tags">
                    {% for i in range(1, titlePartsEs.length) %}
                        <span class="project-tag">{{ titlePartsEs[i] }}</span>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
            {% endif %}
            <a href="{{ project.url | url }}" class="project-thumbnail">
                <div class="thumbnail-wrapper">
                    <img src="{{ project.data.thumbnail | url }}" alt="{{ project.data.title }} preview" class="thumbnail-image">
                </div>
                <div class="thumbnail-overlay lang-en">
                    <ul class="hover-list">
                    {% set items = project.data.hover_description.split('<br>') %}
                    {% for item in items %}
                        {% set clean_item = item | replace("•", "") | trim %}
                        <li>{{ clean_item | safe }}</li>
                    {% endfor %}
                    </ul>
                </div>
                {% if project.data.hover_description_es %}
                <div class="thumbnail-overlay lang-es">
                    <ul class="hover-list">
                    {% set itemsEs = project.data.hover_description_es.split('<br>') %}
                    {% for item in itemsEs %}
                        {% set clean_item_es = item | replace("•", "") | trim %}
                        <li>{{ clean_item_es | safe }}</li>
                    {% endfor %}
                    </ul>
                </div>
                {% endif %}
            </a>
        </div>
        {% endfor %}
    </div>
</section>
{% endfor %}

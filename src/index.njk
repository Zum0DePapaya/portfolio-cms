<h2 class="heading-primary section-title" id="games">Games</h2>

<!-- Games Section -->
<section class="section-container games-section">
    <div class="games-grid">
        {% for project in collections.games %}
        {% if project.data.full_width %}
    </div>
    <hr class="divider">
    <div class="games-grid">
        {% endif %}
        <div class="project-item {% if project.data.full_width %}full-width{% endif %}">
            <p class="text-body project-title"><strong>{{ project.data.title }}</strong></p>
            <a href="{{ project.url | url }}" class="project-thumbnail">
                <div class="thumbnail-wrapper">
                    <img src="{{ project.data.thumbnail | url }}" alt="{{ project.data.title }} preview" class="thumbnail-image">
                </div>
                <div class="thumbnail-overlay">
                    {{ project.data.hover_description | safe }}
                </div>
            </a>
        </div>
        {% endfor %}
    </div>
</section>

<h2 class="heading-primary section-title" id="tools">Tools</h2>

<!-- Tools Section -->
<section class="section-container tools-section">
    <div class="tools-grid">
        {% for project in collections.tools %}
        {% if project.data.full_width %}
    </div>
    <hr class="divider">
    <div class="tools-grid">
        {% endif %}
        <div class="project-item {% if project.data.full_width %}full-width{% endif %}">
            <p class="text-body project-title"><strong>{{ project.data.title }}</strong></p>
            <a href="{{ project.url | url }}" class="project-thumbnail">
                <div class="thumbnail-wrapper">
                    <img src="{{ project.data.thumbnail | url }}" alt="{{ project.data.title }} preview" class="thumbnail-image">
                </div>
                <div class="thumbnail-overlay">
                    {{ project.data.hover_description | safe }}
                </div>
            </a>
        </div>
        {% endfor %}
    </div>
</section>
